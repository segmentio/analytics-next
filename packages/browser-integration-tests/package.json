{
  "name": "@internal/browser-integration-tests",
  "version": "0.0.0",
  "private": true,
  "installConfig": {
    "hoistingLimits": "workspaces"
  },
  "scripts": {
    "test:int": "playwright test",
    "test:conversion-sdk": "playwright test src/conversion-sdk",
    "pretest:conversion-sdk": "mkdir -p conversion-sdk && cp ../browser/dist/umd/sdk.min.js conversion-sdk/sdk.min.js",
    "lint": "yarn concurrently 'yarn:eslint .' 'yarn:tsc --noEmit'",
    "concurrently": "yarn run -T concurrently",
    "watch:test": "yarn test --watch",
    "tsc": "yarn run -T tsc",
    "eslint": "yarn run -T eslint",
    "server": "http-server --port 3000",
    "browser": "playwright test --debug"
  },
  "packageManager": "yarn@3.4.1",
  "devDependencies": {
    "@internal/config": "workspace:^",
    "@internal/test-helpers": "workspace:^",
    "@playwright/test": "^1.61.0",
    "@segment/analytics-next": "workspace:^",
    "http-server": "14.1.1",
    "tslib": "^2.4.1"
  }
}
