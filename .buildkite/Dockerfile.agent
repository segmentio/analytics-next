# Chromium comes from the OS package manager (apk), not Playwright's own installer --
# `playwright install` fetches the browser binary from playwright.azureedge.net
# (and estimo/size-limit separately fetches from storage.googleapis.com), both
# unreachable from locked-down Buildkite agents. apk's Alpine package repos are
# reachable. Matches the working pattern in segmentio/analytics.js-integrations
# .buildkite/Dockerfile.ci.
FROM registry.twilio.com/library/base-node/22:22

RUN apk update && apk add --no-cache \
      chromium \
      nss \
      freetype \
      harfbuzz \
      ca-certificates \
      ttf-freefont \
      git \
      openssh-client \
      python3 \
      g++ \
      make

ENTRYPOINT []
