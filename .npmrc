# Auth for publishing the @be-growth scope to GitHub Packages.
# Used by `npm publish` (scripts/publish-github-package.cjs) — NOT by yarn install
# (Yarn 3 reads .yarnrc.yml, so this file does not affect the @segment/* resolution).
#
# The token is read from the GITHUB_PACKAGES_TOKEN env var — never hardcode it here.
# PAT scopes: write:packages + repo, SSO-authorized for the be-growth org.
@be-growth:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${GITHUB_PACKAGES_TOKEN}
